#include <math.h>

#include "tensorflow/lite/core/c/common.h"
#include "tensorflow/lite/micro/micro_interpreter.h"
#include "tensorflow/lite/micro/micro_mutable_op_resolver.h"
#include "tensorflow/lite/micro/system_setup.h"
#include "tensorflow/lite/schema/schema_generated.h"

#include "models/fastdepth_320_int8.h"
#include "models/model_full_integer_quant_128x160.h"

#define IMG_WIDTH 160
#define IMG_HEIGHT 128

TfLiteStatus RunFastDepth() {

  // Load model
  const tflite::Model* model =
      tflite::GetModel(fastdepth_320_int8_tflite);
  MicroPrintf("Got Model");

  if (model->version() != TFLITE_SCHEMA_VERSION) {
    MicroPrintf("Model schema mismatch!\n");
    return kTfLiteError;
  }

  // Register required ops
  tflite::MicroMutableOpResolver<8> resolver;
  resolver.AddQuantize();
  resolver.AddConv2D();
  resolver.AddRelu6();
  resolver.AddPad();
  resolver.AddDepthwiseConv2D();
  resolver.AddResizeNearestNeighbor();
  resolver.AddAdd();
  resolver.AddRelu();

  MicroPrintf("Added resolvers");

  const int kTensorArenaSize = 5 * 1024 * 1024;
  static uint8_t tensor_arena[kTensorArenaSize];

  tflite::MicroInterpreter interpreter(
      model, resolver, tensor_arena, kTensorArenaSize);

  MicroPrintf("Made Interpreter");
  if (interpreter.AllocateTensors() != kTfLiteOk) {
	  MicroPrintf("AllocateTensors failed\n");
    return kTfLiteError;
  }
  MicroPrintf("Alloacted Tensors");

  TfLiteTensor* input  = interpreter.input(0);
  TfLiteTensor* output = interpreter.output(0);

  MicroPrintf("%d Input dims: %d x %d x %d",
		  	  input->dims->data[1],
              input->dims->data[1],
              input->dims->data[2],
              input->dims->data[3]);

  MicroPrintf("%d Output dims: %d x %d x %d",
              output->dims->data[1],
			  output->dims->data[1],
              output->dims->data[2],
              output->dims->data[3]);

  // --------------------------------------------------
  // Fill input with dummy test pattern
  // --------------------------------------------------

  int input_size = input->bytes;

  for (int i = 0; i < input_size; i++) {
    input->data.int8[i] = 0;  // black image
  }

  // Quantize input
  float scale = input->params.scale;
  int zero    = input->params.zero_point;

  for (int i = 0; i < IMG_WIDTH * IMG_HEIGHT * 3; i++) {
    float normalized = input->data.int8[i] / 255.0f;
    int32_t q = (int32_t)(normalized / scale + zero);
    if (q > 255) q = 255;
    if (q < 0) q = 0;
    input->data.int8[i] = (int8_t)q;
  }

  MicroPrintf("Running inference...\n");

  if (interpreter.Invoke() != kTfLiteOk) {
    MicroPrintf("Inference failed\n");
    return kTfLiteError;
  }

  MicroPrintf("Inference complete.\n");

  // --------------------------------------------------
  // Print some output statistics
  // --------------------------------------------------

  // Dequantize output
  float out_scale = output->params.scale;
  int out_zero    = output->params.zero_point;

  uint8_t depth_img[IMG_WIDTH * IMG_HEIGHT];

  float depth_min = 255.0f;
  float depth_max = 0.0f;
  for (int i = 0; i < IMG_WIDTH * IMG_HEIGHT; i++) {
    float depth = ((float)output->data.int8[i] - out_zero) * out_scale;
    if (depth > depth_max) depth_max = depth;
    if (depth < depth_min) depth_min = depth;
  }

  for (int i = 0; i < IMG_WIDTH * IMG_HEIGHT; i++) {
    float depth = ((float)output->data.int8[i] - out_zero) * out_scale;
    depth_img[i] = 255.0f * (depth - depth_min) / (depth_max - depth_min + 1e-8);
  }

  for (int i = 0; i < IMG_WIDTH * IMG_HEIGHT; i++) {
    MicroPrintf("Depth[%d] = %d", i, depth_img[i]);
  }

  return kTfLiteOk;
}


int main() {
	MicroPrintf("Started");
  tflite::InitializeTarget();
  MicroPrintf("Initialization done");
  TF_LITE_ENSURE_STATUS(RunFastDepth());
  MicroPrintf("Done.");
  return 0;
}

